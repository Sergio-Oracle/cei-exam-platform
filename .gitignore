# ============================================================
# CEI — Centre d'Examen Intelligent | .gitignore
# ============================================================

# Environment variables (NEVER commit real credentials)
.env
*.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
*.egg

# Database files (local SQLite, backups)
*.db
*.sqlite
*.sqlite3
exam_grading_backup.sql
database/

# Uploaded files (user data — managed outside git)
static/uploads/*
!static/uploads/.gitkeep
exports/*
!exports/.gitkeep
exams/*
!exams/.gitkeep

# Logs
*.log
nohup.out
logs/

# Backup files
*.backup*
*.bak
*_backup_*
*_bakup*

# Python cache
.cache/
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# PM2 logs
.pm2/

# Temporary files
tmp/
temp/
*.tmp

# Backup files auto-générés par les scripts
*.bak-*
*-backup-*

# Agent Proctor — fichier d'alertes runtime (généré automatiquement)
agent_alerts.json

# Fichiers de test
test_deepseek.py

# Doublon proctor_dashboard.html à la racine
/proctor_dashboard.html

# Fichiers de déploiement spécifiques à l'instance
egress.yaml
backups/
