# ============================================================
# CEI — Centre d'Examen Intelligent
# Environment Variables Template
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# ----------------------------------------------------------
# API Keys
# ----------------------------------------------------------
# Clé API Anthropic pour la correction IA
# Obtenir sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------
# Flask Configuration
# ----------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=False
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=votre_secret_key_aleatoire_ici
JWT_SECRET_KEY=votre_jwt_secret_key_aleatoire_ici

# ----------------------------------------------------------
# PostgreSQL Configuration
# ----------------------------------------------------------
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://exam_user:votre_mot_de_passe@localhost:5432/exam_grader_db

# ----------------------------------------------------------
# Upload Configuration
# ----------------------------------------------------------
MAX_FILE_SIZE=16777216
ALLOWED_EXTENSIONS=pdf,docx,doc,txt
UPLOAD_FOLDER=static/uploads

# ----------------------------------------------------------
# Application Settings
# ----------------------------------------------------------
ITEMS_PER_PAGE=10
APP_URL=https://votre-domaine.com

# ----------------------------------------------------------
# Configuration Email (SMTP)
# ----------------------------------------------------------
# Pour Gmail : créer un "Mot de passe d'application" dans
# Compte Google → Sécurité → Authentification 2 facteurs
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application_gmail
SMTP_FROM_EMAIL=votre.email@gmail.com
SMTP_FROM_NAME=CEI — Centre d'Examen Intelligent

# Variables alternatives pour compatibilité
SMTP_HOST=smtp.gmail.com
SMTP_USER=votre.email@gmail.com
FROM_EMAIL=votre.email@gmail.com

# ----------------------------------------------------------
# Configuration LiveKit (Surveillance / Proctoring)
# ----------------------------------------------------------
# LiveKit est un serveur WebRTC open-source pour la vidéo en temps réel
# Docs : https://docs.livekit.io/
LIVEKIT_URL=wss://livekit.votre-domaine.com
LIVEKIT_API_KEY=votre_livekit_api_key
LIVEKIT_API_SECRET=votre_livekit_api_secret

# ----------------------------------------------------------
# Configuration S3 (Stockage des enregistrements LiveKit)
# ----------------------------------------------------------
# Compatible MinIO (auto-hébergé) ou AWS S3
S3_KEY_ID=votre_s3_access_key
S3_KEY_SECRET=votre_s3_secret_key
S3_ENDPOINT=https://s3.votre-domaine.com
S3_BUCKET=livekit-recordings
S3_REGION=us-east-1
