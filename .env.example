ANTHROPIC_API_KEY=sk-ant-api03-VOTRE_CLE_ICI
GEMINI_API_KEY=AIzaSy-VOTRE_CLE_ICI
GEMINI_API_KEY_2=AIzaSy-DEUXIEME_CLE_OPTIONNELLE
DEEPSEEK_API_KEY=sk-VOTRE_CLE_DEEPSEEK

OLLAMA_API_URL=https://votre-serveur-ollama.exemple.sn
OLLAMA_API_KEY=votre-cle-api-ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_MODEL_FAST=gemma3:12b

FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=CHANGEZ-MOI-cle-secrete-longue-aleatoire-min-32-caracteres
JWT_SECRET_KEY=CHANGEZ-MOI-autre-cle-secrete-jwt-min-32-caracteres

DATABASE_URL=postgresql://exam_user:VOTRE_MOT_DE_PASSE@localhost:5432/exam_grader_db

APP_URL=https://votre-domaine.sn
MAX_FILE_SIZE=16777216
ALLOWED_EXTENSIONS=pdf,docx,doc,txt
UPLOAD_FOLDER=static/uploads
ITEMS_PER_PAGE=10

SMTP_SERVER=votre-serveur-smtp.sn
SMTP_PORT=587
SMTP_USERNAME=votre-utilisateur-smtp
SMTP_PASSWORD=votre-mot-de-passe-smtp
