S3_KEY_ID=votre-access-key
S3_KEY_SECRET=votre-secret-key
S3_ENDPOINT=http://votre-minio:9000
S3_BUCKET=livekit-recordings
S3_REGION=us-east-1

AGENT_SECRET_KEY=CHANGEZ-MOI-cle-secrete-agent-unique-min-32-caracteres
AGENT_RISK_ALERT=60
AGENT_RISK_URGENT=80
AGENT_CHECK_INTERVAL=30
